{
  "name": "a1-mini-auto-swap",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Bambu A1 mini multi-plate auto-print orchestrator + printer-stub (self-hosted controller host, no-cloud)",
  "scripts": {
    "stub": "bun run src/stub/main.ts",
