# Copy to `.env` (gitignored) and fill in. Bun auto-loads `.env`.
# This repo is PUBLIC — never commit real addresses, access codes, SSIDs, or keys.
# Environment-specific values (tailnet IPs / MagicDNS names, printer access code)
# live only in your local `.env`. Find tailnet addresses via `tailscale status`.

# ── printer-stub (development mock; src/stub) ─────────────────────────────────
STUB_SERIAL=STUB0001
STUB_MQTT_PORT=8883
STUB_FTPS_PORT=990          # implicit FTPS; 990 is privileged — use e.g. 9990 on a non-root dev host
STUB_HTTP_PORT=3001
STUB_SPEED_FACTOR=1000
STUB_ACCESS_CODE=change-me
STUB_CERT_DIR=./certs
STUB_UPLOAD_DIR=./.tmp/ftps-uploads

# ── orchestrator ↔ real A1 mini (Phase 8) ────────────────────────────────────
# PRINTER_HOST=                 # A1 mini address (LAN IP or tailnet name)
# PRINTER_ACCESS_CODE=          # printer LAN access code (secret)
# PRINTER_SERIAL=

# ── notifications (Phase 7) ───────────────────────────────────────────────────
# DISCORD_WEBHOOK_URL=          # Discord/Slack incoming webhook (secret)
# BASE_URL=http://<controller-tailnet-name>:3000   # for deep links in notifications

# ── self-hosted Mosquitto gateway on the controller host (Phase 7) ────────────
# MOSQUITTO_URL=mqtt://<controller-tailnet-name>:1883

# ── Tab5 monitor deploy (frontend/tab5) ───────────────────────────────────────
# Used by a deploy step to inject the broker into the app before pushing;
# the app itself defaults to the firmware sdkconfig broker when BROKER="".
# TAB5_BROKER_URL=mqtt://<controller-tailnet-name>:1883
